---
import BaseLayout from "../layouts/BaseLayout.astro";

const seoTitle: string = "Lex Astro - About";
const pageTitle: string = "Serhii lavrenov - the full-stack developer.";

const sectionMySkills: string = "My skills";
const identity = {
    firstName: "Serhii",
    workPrefferance: "Remotely",
    occupation: "Full-stack developer",
    hobbies: ["electronics", "drumming", "table tennis"]
};

const skillColor = "crimson";
const fontWeight = "normal";
const textCase = "none";
const skills = [
    "HTML",
    "CSS",
    "JavaScript",
    "React",
    "Astro",
    "Node.js",
    "Hono",
    "AI"
];

const happy = true;
const finished = true;
const goal = 3;
---

<style define:vars={{ skillColor, fontWeight, textCase }}>
    h1 {
        color: purple;
        font-size: 4rem;
    }
    .skill {
        color: var(--skillColor);
        font-weight: var(--fontWeight);
        text-transform: var(--textCase);
    }
</style>

<BaseLayout seoTitle={seoTitle}>
    <h1>{pageTitle}</h1>
    <p>I worry about best quality for the least $/month maintaining.</p>

    <section>
        <h2>{sectionMySkills}</h2>
        <ul>
            <li>My name is {identity.firstName}.</li>
            <li>
                I work {identity.workPrefferance} as a {identity.occupation}.
            </li>
            {
                identity.hobbies.length >= 2 && (
                    <li>
                        My hobbies are:{" "}
                        {identity.hobbies.map((hobby, i) =>
                            /* prettier-ignore */
                            <span>{hobby}{i < identity.hobbies.length - 2 ? ", " : ""}{i === identity.hobbies.length - 2 ? " and " : ""}</span>
                        )}
                    </li>
                )
            }
        </ul>
        <p>My skills are:</p>
        <ul>
            {skills.map((skill) => <li class="skill">{skill}</li>)}
        </ul>
    </section>

    <section>
        <h2>Learning Logic in Astro</h2>
        {happy && <p>I am happy to be learning Astro!</p>}

        {finished && <p>I finished this tutorial!</p>}

        {
            goal === 3 ? (
                <p>My goal is to finish in 3 days.</p>
            ) : (
                <p>My goal is not 3 days.</p>
            )
        }
    </section>
</BaseLayout>
